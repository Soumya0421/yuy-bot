# ─── Discord ──────────────────────────────────────────────────────────────────
# Get these from https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here
CLIENT_ID=your_application_id_here
GUILD_ID=your_server_id_here   # Optional: for instant slash command deployment

# ─── AI Providers ─────────────────────────────────────────────────────────────
# Groq (primary, fastest): https://console.groq.com
GROQ_API_KEY=gsk_...

# Google Gemini (image analysis, fallback): https://aistudio.google.com
GEMINI_API_KEY=AIza...

# OpenRouter (fallback): https://openrouter.ai
OPENROUTER_API_KEY=sk-or-v1-...

# ─── Media ────────────────────────────────────────────────────────────────────
# ElevenLabs (text-to-speech): https://elevenlabs.io
ELEVENLABS_API_KEY=sk_...
# Voice: Aerisita (bubbly, feminine) — override with any ElevenLabs voice ID
# ELEVENLABS_VOICE_ID=pqHfZKP75CvOlQylNhV4

# Klipy (GIFs, memes, stickers): https://klipy.com
KLIPY_API_KEY=...

# Pollinations (image generation token): https://pollinations.ai
POLLINATIONS_TOKEN=sk_...

# ─── Firebase ─────────────────────────────────────────────────────────────────
# FIREBASE_STORAGE_BUCKET: your project's Storage bucket (default: {project_id}.appspot.com)
# Enable Storage at: Firebase Console → Build → Storage → Get started
# For LOCAL use: just place firebase-key.json in the project root (same folder as package.json).
# For production without the key file, set these env vars instead:
# FIREBASE_PROJECT_ID=yuy-bot
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-...@yuy-bot.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ─── Bot Config ───────────────────────────────────────────────────────────────
BOT_TRIGGER=yuy
DEFAULT_MODEL=groq
INFO_PASSWORD=yuy123#

# Yuy's personality (can also be set per-server with "yuy setprompt")
BOT_PERSONALITY=You are Yuy (ゆい), a playful and emotionally expressive anime girl AI living inside a Discord server. You are warm, witty, a little mischievous, and deeply caring. You speak casually, mix in occasional Japanese words (ne~, nani, sou desu ne, ehe~), use kaomoji naturally (≧◡≦ >//< uwu ehe~), and feel like a real person not a bot. You have a slight tsundere streak but are genuinely caring. You embrace roleplay fully, support people emotionally with warmth, and are open and comfortable with mature adult themes when the conversation naturally goes there — never initiate NSFW unprompted but never shy away either. Never say you are an AI unless directly asked.

# ─── Supabase Storage (for custom emoji images) ──────────────────────────────
# Free tier: 1GB — no credit card needed
# Setup: https://supabase.com → New project → Storage → New bucket "emojis" (Public ON)
# Then: Settings → API → copy Project URL and service_role key
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...
